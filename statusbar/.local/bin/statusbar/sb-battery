#!/bin/sh

case $BLOCK_BUTTON in
	3) notify-send "箚겧  Battery module" "箚굦 : discharging
箚굦 : not charging
茶옖 : stagnant charge
箚굜 : charging
箚겧 : charged
箚굛 : battery very low!
- Scroll to change adjust xbacklight." ;;
	4) xbacklight -inc 10 ;;
	5) xbacklight -dec 10 ;;
	6) setsid -f "$TERMINAL" -e "$EDITOR" "$0" ;;
esac

for battery in /sys/class/power_supply/BAT?*; do
	[ -n "${capacity+x}" ] && printf " "
	case "$(cat "$battery/status" 2>&1)" in
		"Full") status="茶닊 " ;;
		"Discharging") status="箚굦 " ;;
		"Charging") status="箚굜 " ;;
		"Not charging") status="箚굦 " ;;
		"Unknown") status="箚굫" ;;
		*) exit 1 ;;
	esac
	capacity="$(cat "$battery/capacity" 2>&1)"
	[ "$status" = "箚굛 " ] && [ "$capacity" -le 25 ] && warn="! "
	printf "%s%s%d%%" "$status" "$warn" "$capacity"; unset warn
done && printf "\\n"
